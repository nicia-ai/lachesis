{
  "name": "@nicia-ai/lachesis-cli",
  "version": "0.1.0",
  "description": "Command-line plan inspector and replay runner for Lachesis",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Nicia AI",
  "private": true,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "lachesis": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nicia-ai/lachesis.git",
    "directory": "apps/cli"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@nicia-ai/lachesis": "workspace:*",
    "@nicia-ai/lachesis-generator": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3"
  }
}
