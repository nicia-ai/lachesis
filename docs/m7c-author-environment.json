{
  "schemaVersion": 1,
  "kind": "lachesis-m7c-isolated-agent-author-environment",
  "runtime": {
    "node": "24.x",
    "pnpm": "10.33.0",
    "typescript": "6.0.3",
    "zod": "4.4.3",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": false,
    "strict": true
  },
  "isolation": {
    "freshSessionPerAuthor": true,
    "network": "disabled",
    "sharedMemory": false,
    "sharedConversation": false,
    "sharedFilesystem": false,
    "mutableCrossAssignmentCache": false,
    "repositoryCheckoutPresent": false,
    "credentialsPresent": false
  },
  "allowedInputs": [
    "frozen-alpha3-tarballs",
    "frozen-public-documentation",
    "frozen-author-instructions",
    "assigned-fresh-catalog-packet"
  ],
  "actualEnvironmentImageDigest": "required-before-execution",
  "executionAuthorized": false
}
