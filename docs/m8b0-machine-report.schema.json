                              "id": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 128,
                                "pattern": "^[A-Za-z0-9._:/-]+$"
                              },
                              "version": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 64
                              }
                            },
                            "required": [
                              "id",
                              "version"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "boundary": {
                        "type": "string",
                        "minLength": 1
                      },
                      "obligation": {
                        "type": "string",
                        "minLength": 1
                      },
                      "explanation": {
                        "type": "string",
                        "minLength": 1
                      },
                      "action": {
                        "oneOf": [
