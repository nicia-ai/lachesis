                                "enum": [
                                  "left",
                                  "right",
                                  "both"
                                ]
                              },
                              "operation": {
                                "type": "string",
                                "enum": [
                                  "add-role",
                                  "align-role-version",
                                  "align-obligations"
                                ]
                              },
                              "role": {
                                "anyOf": [
                                  {
                                    "readOnly": true,
                                    "type": "object",
                                    "properties": {
                                      "id": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 128,
                                        "pattern": "^[A-Za-z0-9._:/-]+$"
                                      },
                                      "version": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 64
                                      }
                                    },
                                    "required": [
                                      "id",
                                      "version"
                                    ],
                                    "additionalProperties": false
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "patchDescription": {
                                "type": "string",
                                "minLength": 1
                              },
                              "safetyCondition": {
                                "type": "string",
                                "minLength": 1
                              }
