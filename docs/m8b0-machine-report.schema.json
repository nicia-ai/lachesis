{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "readOnly": true,
  "type": "object",
  "properties": {
    "protocol": {
      "type": "string",
      "const": "lachesis-catalog-command-report/1"
    },
    "command": {
      "readOnly": true,
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "catalog.manifest",
            "catalog.compare",
            "report.verify"
          ]
        },
        "version": {
          "type": "string",
          "const": "1"
        },
        "commandIdentity": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "required": [
        "id",
        "version",
        "commandIdentity"
      ],
      "additionalProperties": false
    },
    "inputs": {
      "readOnly": true,
      "type": "array",
      "items": {
        "readOnly": true,
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "catalog",
              "catalog-manifest",
              "conformance-suite",
              "plan",
              "policy",
              "report"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "required": [
          "kind",
          "label",
          "digest"
        ],
        "additionalProperties": false
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "review-required",
        "rejected",
        "invalid",
        "incomplete",
        "internal-error"
      ]
    },
    "completeness": {
      "type": "string",
      "enum": [
        "complete",
        "partial"
      ]
    },
    "outcomeExitCode": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 10
        },
        {
          "type": "number",
          "const": 11
        },
        {
          "type": "number",
          "const": 12
        },
        {
          "type": "number",
          "const": 13
        },
        {
          "type": "number",
          "const": 20
        },
        {
          "type": "number",
          "const": 21
        },
        {
          "type": "number",
          "const": 22
        },
        {
          "type": "number",
          "const": 23
        },
        {
          "type": "number",
          "const": 70
        }
      ]
    },
    "diagnostics": {
      "readOnly": true,
      "type": "object",
      "properties": {
        "controller": {
          "readOnly": true,
          "type": "array",
          "items": {
            "readOnly": true,
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "INVALID_CATALOG",
                  "INVALID_MANIFEST",
                  "INVALID_POLICY",
                  "INVALID_SUITE",
                  "INVALID_REPORT",
                  "UNSUPPORTED_PROTOCOL",
                  "IDENTITY_MISMATCH",
                  "CHECKSUM_MISMATCH",
                  "INCOMPLETE_EXECUTION",
                  "INTERNAL_CONTROLLER_FAILURE"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "location": {
                "readOnly": true,
                "type": "object",
                "properties": {
                  "artifactId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "fieldPath": {
                    "readOnly": true,
                    "type": "array",
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        }
                      ]
                    }
                  }
                },
                "required": [
                  "fieldPath"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "code",
              "message",
              "location"
            ],
            "additionalProperties": false
          }
        },
        "validationAttempts": {
          "readOnly": true,
          "type": "array",
          "items": {
            "readOnly": true,
            "type": "object",
            "properties": {
              "attemptIdentity": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "subject": {
                "readOnly": true,
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "catalog",
                      "catalog-manifest",
                      "conformance-suite",
                      "plan",
                      "policy",
                      "report"
                    ]
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "digest": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  }
                },
                "required": [
                  "kind",
                  "label",
