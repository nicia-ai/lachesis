                ],
                "additionalProperties": false
              },
              "result": {
                "type": "string",
                "enum": [
                  "accepted",
                  "rejected"
                ]
              },
              "diagnostics": {
                "readOnly": true,
                "type": "array",
                "items": {
                  "readOnly": true,
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "enum": [
                        "MALFORMED_JSON",
                        "INVALID_WIRE_SCHEMA",
                        "UNSUPPORTED_PLAN_VERSION",
                        "DUPLICATE_NODE_ID",
                        "MISSING_ROOT",
                        "MISSING_NODE_REFERENCE",
                        "GRAPH_CYCLE",
                        "DEAD_NODE",
                        "UNKNOWN_SCHEMA",
                        "UNKNOWN_OPERATION",
                        "OPERATION_KIND_MISMATCH",
                        "TYPE_MISMATCH",
                        "INVALID_REDUCER",
                        "BRANCH_TYPE_MISMATCH",
                        "UNDECLARED_EFFECT",
                        "DENIED_CAPABILITY",
                        "UNBOUNDED_CARDINALITY",
                        "UNBOUNDED_RECURSION",
                        "NON_DECREASING_RECURSION_MEASURE",
                        "BUDGET_EXCEEDED",
                        "SEMANTIC_OBLIGATION_FAILED",
                        "INVALID_INFEASIBILITY_WITNESS",
                        "RUNTIME_SCHEMA_VIOLATION",
                        "MISSING_REPLAY_RESULT",
                        "REPLAY_REQUEST_MISMATCH",
                        "REPLAY_OUTPUT_MISMATCH",
                        "INVALID_EXECUTABLE_PLAN",
                        "CATALOG_REFERENCE_MISMATCH",
                        "INTERNAL_INVARIANT_VIOLATION"
                      ]
                    },
                    "message": {
                      "type": "string",
                      "minLength": 1
                    },
                    "location": {
                      "readOnly": true,
                      "type": "object",
                      "properties": {
                        "nodeId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "path": {
                          "readOnly": true,
                          "type": "array",
                          "items": {
                            "anyOf": [
                              {
                                "type": "string"
                              },
                              {
                                "type": "number"
                              }
                            ]
                          }
                        }
                      },
                      "additionalProperties": false
                    },
                    "details": {
                      "readOnly": true,
                      "type": "array",
                      "items": {
                        "readOnly": true,
                        "type": "object",
                        "properties": {
                          "key": {
                            "type": "string",
                            "minLength": 1
                          },
                          "value": {
                            "anyOf": [
                              {
                                "type": "string"
                              },
                              {
                                "type": "number"
                              },
                              {
                                "type": "boolean"
                              }
                            ]
                          }
                        },
                        "required": [
                          "key",
                          "value"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "expected": {
                      "readOnly": true,
                      "type": "object",
                      "properties": {
                        "schema": {
                          "readOnly": true,
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "version": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "id",
                            "version"
                          ],
                          "additionalProperties": false
                        },
                        "reference": {
                          "readOnly": true,
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "enum": [
                                "schema",
                                "operation",
                                "catalog",
                                "effectRequest"
                              ]
                            },
                            "id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "version": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "kind",
                            "id"
                          ],
                          "additionalProperties": false
                        },
                        "value": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "number"
                            },
                            {
                              "type": "boolean"
                            }
                          ]
                        }
                      },
                      "additionalProperties": false
                    },
                    "actual": {
                      "readOnly": true,
                      "type": "object",
                      "properties": {
                        "schema": {
                          "readOnly": true,
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "version": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "id",
                            "version"
                          ],
                          "additionalProperties": false
                        },
                        "reference": {
                          "readOnly": true,
                          "type": "object",
                          "properties": {
                            "kind": {
                              "type": "string",
                              "enum": [
                                "schema",
                                "operation",
                                "catalog",
                                "effectRequest"
                              ]
                            },
                            "id": {
                              "type": "string",
                              "minLength": 1
                            },
                            "version": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "kind",
                            "id"
                          ],
                          "additionalProperties": false
                        },
                        "value": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "number"
                            },
                            {
                              "type": "boolean"
                            }
                          ]
                        }
                      },
                      "additionalProperties": false
                    },
                    "limit": {
                      "readOnly": true,
                      "type": "object",
                      "properties": {
                        "resource": {
                          "type": "string",
                          "minLength": 1
                        },
                        "limit": {
                          "type": "number"
                        },
                        "actual": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "resource",
                        "limit",
                        "actual"
                      ],
                      "additionalProperties": false
                    },
                    "repair": {
                      "readOnly": true,
                      "type": "object",
                      "properties": {
                        "nodeId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "path": {
                          "readOnly": true,
                          "type": "array",
                          "items": {
                            "anyOf": [
                              {
                                "type": "string"
                              },
                              {
                                "type": "number"
                              }
                            ]
                          }
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "code",
                    "message",
                    "location",
                    "details"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "attemptIdentity",
              "subject",
              "result",
              "diagnostics"
            ],
            "additionalProperties": false
          }
        },
        "conformance": {
          "readOnly": true,
          "type": "array",
          "items": {
            "readOnly": true,
            "type": "object",
            "properties": {
              "recordIdentity": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "comparisonIdentity": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "result": {
                "type": "string",
                "enum": [
                  "conformant",
                  "rejected"
                ]
              },
              "reportIdentity": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                  },
                  {
                    "type": "null"
