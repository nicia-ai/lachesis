                        "additionalProperties": false
                      },
                      "diagnosticDigest": {
                        "type": "string",
                        "pattern": "^[a-f0-9]{64}$"
                      },
                      "recordDigest": {
                        "type": "string",
                        "pattern": "^[a-f0-9]{64}$"
                      }
                    },
                    "required": [
                      "protocol",
                      "code",
                      "outcome",
