                          "INCOMPATIBLE_OBLIGATIONS",
                          "INCOMPLETE_FIXTURE_EVIDENCE",
                          "DUPLICATE_FIXTURE_EVIDENCE",
                          "SCHEMA_BOUNDARY_MISMATCH",
                          "OPERATION_SIGNATURE_MISMATCH",
                          "CAPABILITY_MISMATCH",
                          "EFFECT_CONTRACT_MISMATCH",
                          "ORDERING_SEMANTICS_MISMATCH",
