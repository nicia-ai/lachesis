                            "required": [
                              "kind",
                              "mechanical",
                              "side",
                              "operation",
                              "role",
                              "patchDescription",
                              "safetyCondition"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "readOnly": true,
                            "type": "object",
                            "properties": {
                              "kind": {
                                "type": "string",
                                "const": "edit-suite"
                              },
                              "mechanical": {
                                "type": "boolean",
                                "const": true
                              },
                              "operation": {
                                "type": "string",
                                "enum": [
                                  "add-fixture",
                                  "remove-duplicate-fixture"
                                ]
                              },
                              "role": {
                                "anyOf": [
                                  {
                                    "readOnly": true,
                                    "type": "object",
                                    "properties": {
                                      "id": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 128,
                                        "pattern": "^[A-Za-z0-9._:/-]+$"
                                      },
                                      "version": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 64
                                      }
                                    },
                                    "required": [
                                      "id",
                                      "version"
                                    ],
                                    "additionalProperties": false
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "patchDescription": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "required": [
                              "kind",
                              "mechanical",
                              "operation",
                              "role",
                              "patchDescription"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "readOnly": true,
                            "type": "object",
                            "properties": {
                              "kind": {
                                "type": "string",
                                "const": "do-not-substitute"
                              },
                              "mechanical": {
                                "type": "boolean",
                                "const": false
                              },
                              "violatedObligation": {
                                "type": "string",
                                "minLength": 1
                              },
                              "reason": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "required": [
                              "kind",
                              "mechanical",
                              "violatedObligation",
                              "reason"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "readOnly": true,
                            "type": "object",
                            "properties": {
                              "kind": {
                                "type": "string",
                                "const": "no-safe-repair"
                              },
                              "mechanical": {
                                "type": "boolean",
                                "const": false
                              },
                              "reason": {
                                "type": "string",
                                "minLength": 1
                              }
                            },
                            "required": [
                              "kind",
                              "mechanical",
                              "reason"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      },
